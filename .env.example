# ── Banco de dados ──────────────────────────────────────────────────────────────
# Dev: SQLite (padrão)
DATABASE_URL=sqlite:///./dev.db
# Prod: Railway fornece automaticamente ao adicionar o plugin PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Segurança ────────────────────────────────────────────────────────────────────
# Gere um valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-em-producao

# ── IA ───────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Admin inicial (seed automático no primeiro startup) ──────────────────────────
ADMIN_EMAIL=admin@skolai.com
ADMIN_SENHA=admin123
ADMIN_NOME=Admin

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Dev: deixar "*" (padrão)
# Prod: URL exata do frontend (sem barra no final)
# ALLOWED_ORIGINS=https://skolai-frontend.up.railway.app
ALLOWED_ORIGINS=*
